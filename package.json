{
  "name": "gpca-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server for GPCA card management - bank cards, USDT wallet, KYC, and shopping automation",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gpca-mcp-server": "./dist/index.js"
  },
  "files": [
    "dist/",
    "data/"
  ],
  "keywords": [
    "mcp",
    "gpca",
    "bank-card",
    "mastercard",
    "visa",
    "usdt",
    "crypto-wallet",
    "kyc",
    "openclaw"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.10.0",
    "crypto-js": "^4.2.0",
    "pinyin-pro": "^3.28.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
